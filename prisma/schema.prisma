// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "prisma"
}

datasource db {
  provider = "postgresql"
v
}

model Customer {
  id        Int    @id @default(autoincrement())
  name      String
  phone     String @unique
  history   Product[]
  notes     String?
}

model Product {
  id         Int     @id @default(autoincrement())
  title      String
  price      Int
  type       String
  user       Customer @relation(fields: [id], references: [id])
}

 model Sales_Data {
  id          Int     @id @default(autoincrement())
  passersby   Int
  hooks       Int
  conversions Int
  losses      Int
}